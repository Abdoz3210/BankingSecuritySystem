<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="SecureBankGUI.MainWindow"
        Title="SecureBank Client"
        Width="680" Height="560"
        MinWidth="680" MinHeight="560"
        WindowStartupLocation="CenterScreen"
        Background="White">

  <DockPanel>

    <!-- STATUS BAR (bottom) -->
    <Border DockPanel.Dock="Bottom"
            Background="#F5F5F5"
            BorderBrush="#E0E0E0"
            BorderThickness="0,1,0,0"
            Height="38">
      <Grid Margin="12,0">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <TextBlock x:Name="lblStatus"
                   Grid.Column="0"
                   Text="● Not connected"
                   Foreground="Gray"
                   VerticalAlignment="Center"
                   FontSize="12"/>
        <Button x:Name="btnConnect"
                Grid.Column="1"
                Content="Connect"
                Width="90" Height="26"
                FontSize="12"
                Click="BtnConnect_Click"/>
      </Grid>
    </Border>

    <!-- MAIN TAB CONTROL -->
    <TabControl x:Name="tabControl" Margin="8">

      <!-- ═══════════════════════════ -->
      <!-- BANKING TAB                -->
      <!-- ═══════════════════════════ -->
      <TabItem Header="  Banking  ">
        <StackPanel Margin="16" Spacing="12">

          <!-- Metric cards -->
          <Grid ColumnDefinitions="*,*,*" Height="75">
            <Border Grid.Column="0" Background="#F5F5F5"
                    CornerRadius="8" Margin="0,0,8,0">
              <StackPanel Margin="12,10">
                <TextBlock Text="Current balance"
                           FontSize="11" Foreground="Gray"/>
                <TextBlock x:Name="lblBalance"
                           Text="$1,000"
                           FontSize="22"
                           Foreground="#185FA5"/>
              </StackPanel>
            </Border>
            <Border Grid.Column="1" Background="#F5F5F5"
                    CornerRadius="8" Margin="0,0,8,0">
              <StackPanel Margin="12,10">
                <TextBlock Text="Total deposited"
                           FontSize="11" Foreground="Gray"/>
                <TextBlock x:Name="lblDeposited"
                           Text="$0"
                           FontSize="22"
                           Foreground="#3B6D11"/>
              </StackPanel>
            </Border>
            <Border Grid.Column="2" Background="#F5F5F5"
                    CornerRadius="8">
              <StackPanel Margin="12,10">
                <TextBlock Text="Total withdrawn"
                           FontSize="11" Foreground="Gray"/>
                <TextBlock x:Name="lblWithdrawn"
                           Text="$0"
                           FontSize="22"
                           Foreground="#993C1D"/>
              </StackPanel>
            </Border>
          </Grid>

          <!-- Amount input + buttons -->
          <Grid ColumnDefinitions="*,Auto,Auto" Height="50">
            <TextBox x:Name="txtAmount"
                     Grid.Column="0"
                     Watermark="Enter amount..."
                     Margin="0,0,8,0"
                     FontSize="13"/>
            <Button x:Name="btnDeposit"
                    Grid.Column="1"
                    Content="Deposit"
                    Width="100"
                    Margin="0,0,8,0"
                    Background="#E6F1FB"
                    Foreground="#185FA5"
                    Click="BtnDeposit_Click"/>
            <Button x:Name="btnWithdraw"
                    Grid.Column="2"
                    Content="Withdraw"
                    Width="100"
                    Background="#FAECE7"
                    Foreground="#993C1D"
                    Click="BtnWithdraw_Click"/>
          </Grid>

          <!-- Transaction log -->
          <TextBlock Text="Transaction history"
                     FontSize="11" Foreground="Gray"/>
          <TextBox x:Name="rtbBankLog"
                   IsReadOnly="True"
                   AcceptsReturn="True"
                   Height="220"
                   FontFamily="Monospace"
                   FontSize="11"
                   Background="#F8F8F8"
                   TextWrapping="Wrap"
                   ScrollViewer.VerticalScrollBarVisibility="Auto"
                   Text="— Session not started. Click Connect. —&#10;"/>

        </StackPanel>
      </TabItem>

      <!-- ═══════════════════════════ -->
      <!-- CHAT TAB                   -->
      <!-- ═══════════════════════════ -->
      <TabItem Header="  Support Chat  ">
        <DockPanel Margin="16">

          <!-- Send area (bottom) -->
          <Grid DockPanel.Dock="Bottom"
                ColumnDefinitions="*,Auto"
                Margin="0,8,0,0" Height="36">
            <TextBox x:Name="txtChatMessage"
                     Grid.Column="0"
                     Watermark="Type a message..."
                     Margin="0,0,8,0"
                     FontSize="13"
                     KeyDown="TxtChat_KeyDown"/>
            <Button x:Name="btnSendChat"
                    Grid.Column="1"
                    Content="Send"
                    Width="96"
                    Background="#185FA5"
                    Foreground="White"
                    Click="BtnSendChat_Click"/>
          </Grid>

          <!-- Chat log -->
          <TextBox x:Name="rtbChatLog"
                   IsReadOnly="True"
                   AcceptsReturn="True"
                   FontSize="12"
                   Background="#F8F8F8"
                   TextWrapping="Wrap"
                   ScrollViewer.VerticalScrollBarVisibility="Auto"
                   Text="— Connect to start chatting. —&#10;"/>
        </DockPanel>
      </TabItem>

      <!-- ═══════════════════════════ -->
      <!-- LIVE RATES TAB             -->
      <!-- ═══════════════════════════ -->
      <TabItem Header="  Live Rates  ">
        <StackPanel Margin="16" Spacing="12">

          <!-- Header row -->
          <Grid ColumnDefinitions="*,Auto">
            <TextBlock x:Name="lblLastUpdated"
                       Grid.Column="0"
                       Text="Last updated: —"
                       Foreground="Gray"
                       FontSize="12"
                       VerticalAlignment="Center"/>
            <Button x:Name="btnRefresh"
                    Grid.Column="1"
                    Content="Refresh Rates"
                    Width="120"
                    Click="BtnRefresh_Click"/>
          </Grid>

          <!-- Rate cards grid -->
          <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto"
                ColumnSpacing="12" RowSpacing="12">

            <Border Grid.Row="0" Grid.Column="0"
                    Background="#F5F5F5" CornerRadius="8">
              <StackPanel Margin="14,12">
                <TextBlock Text="USD / EGP"
                           FontSize="11" Foreground="Gray"/>
                <TextBlock x:Name="lblUSD"
                           Text="—" FontSize="26"/>
              </StackPanel>
            </Border>

            <Border Grid.Row="0" Grid.Column="1"
                    Background="#F5F5F5" CornerRadius="8">
              <StackPanel Margin="14,12">
                <TextBlock Text="EUR / EGP"
                           FontSize="11" Foreground="Gray"/>
                <TextBlock x:Name="lblEUR"
                           Text="—" FontSize="26"/>
              </StackPanel>
            </Border>

            <Border Grid.Row="1" Grid.Column="0"
                    Background="#F5F5F5" CornerRadius="8">
              <StackPanel Margin="14,12">
                <TextBlock Text="GBP / EGP"
                           FontSize="11" Foreground="Gray"/>
                <TextBlock x:Name="lblGBP"
                           Text="—" FontSize="26"/>
              </StackPanel>
            </Border>

            <Border Grid.Row="1" Grid.Column="1"
                    Background="#F5F5F5" CornerRadius="8">
              <StackPanel Margin="14,12">
                <TextBlock Text="SAR / EGP"
                           FontSize="11" Foreground="Gray"/>
                <TextBlock x:Name="lblSAR"
                           Text="—" FontSize="26"/>
              </StackPanel>
            </Border>

          </Grid>
        </StackPanel>
      </TabItem>

    </TabControl>
  </DockPanel>
</Window>