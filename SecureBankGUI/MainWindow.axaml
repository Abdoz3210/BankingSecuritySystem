<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="SecureBankGUI.MainWindow"
        Title="SecureBank Client"
        Width="680" Height="580"
        MinWidth="680" MinHeight="580"
        WindowStartupLocation="CenterScreen"
        Background="#0F0F1A"
        RequestedThemeVariant="Dark">

  <DockPanel>

    <Border DockPanel.Dock="Bottom"
            Background="#1A1A2E"
            BorderBrush="#2A2A4A"
            BorderThickness="0,1,0,0"
            Height="44">
      <Grid Margin="16,0">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <TextBlock x:Name="lblStatus"
                   Grid.Column="0"
                   Text="● Not connected"
                   Foreground="#888888"
                   VerticalAlignment="Center"
                   FontSize="12"/>
        <Button x:Name="btnConnect"
                Grid.Column="1"
                Content="Connect"
                Width="100" Height="30"
                FontSize="12"
                Background="#185FA5"
                Foreground="White"
                Click="BtnConnect_Click"/>
      </Grid>
    </Border>

    <TabControl x:Name="tabControl"
                Margin="12"
                Background="#12121F">

      <TabItem Header="  Banking  " FontSize="13" Foreground="White">
        <StackPanel Margin="16" Spacing="14" Background="#12121F">

          <Grid ColumnDefinitions="*,*,*" Height="80">
            <Border Grid.Column="0"
                    Background="#0D2137"
                    BorderBrush="#185FA5"
                    BorderThickness="1"
                    CornerRadius="8"
                    Margin="0,0,8,0">
              <StackPanel Margin="12,10">
                <TextBlock Text="Current balance"
                           FontSize="11" Foreground="#5B9BD5"/>
                <TextBlock x:Name="lblBalance"
                           Text="$1,000"
                           FontSize="22"
                           FontWeight="Bold"
                           Foreground="#60B8FF"/>
              </StackPanel>
            </Border>
            <Border Grid.Column="1"
                    Background="#0D2110"
                    BorderBrush="#2E7D32"
                    BorderThickness="1"
                    CornerRadius="8"
                    Margin="0,0,8,0">
              <StackPanel Margin="12,10">
                <TextBlock Text="Total deposited"
                           FontSize="11" Foreground="#4CAF50"/>
                <TextBlock x:Name="lblDeposited"
                           Text="$0"
                           FontSize="22"
                           FontWeight="Bold"
                           Foreground="#00E676"/>
              </StackPanel>
            </Border>
            <Border Grid.Column="2"
                    Background="#210D0D"
                    BorderBrush="#C62828"
                    BorderThickness="1"
                    CornerRadius="8">
              <StackPanel Margin="12,10">
                <TextBlock Text="Total withdrawn"
                           FontSize="11" Foreground="#EF5350"/>
                <TextBlock x:Name="lblWithdrawn"
                           Text="$0"
                           FontSize="22"
                           FontWeight="Bold"
                           Foreground="#FF5252"/>
              </StackPanel>
            </Border>
          </Grid>

          <Grid ColumnDefinitions="*,Auto,Auto" Height="40">
            <TextBox x:Name="txtAmount"
                     Grid.Column="0"
                     PlaceholderText="Enter amount..."
                     Margin="0,0,8,0"
                     FontSize="13"
                     Background="#1E1E35"
                     Foreground="White"
                     CaretBrush="White"/>
            <Button x:Name="btnDeposit"
                    Grid.Column="1"
                    Content="Deposit"
                    Width="100"
                    Margin="0,0,8,0"
                    Background="#185FA5"
                    Foreground="White"
                    Click="BtnDeposit_Click"/>
            <Button x:Name="btnWithdraw"
                    Grid.Column="2"
                    Content="Withdraw"
                    Width="100"
                    Background="#C62828"
                    Foreground="White"
                    Click="BtnWithdraw_Click"/>
          </Grid>

          <TextBlock Text="Transaction history"
                     FontSize="11" Foreground="#888888"/>
          <TextBox x:Name="rtbBankLog"
                   IsReadOnly="True"
                   AcceptsReturn="True"
                   Height="230"
                   FontFamily="Monospace"
                   FontSize="11"
                   Background="#0A0A15"
                   Foreground="#00FF88"
                   TextWrapping="Wrap"
                   ScrollViewer.VerticalScrollBarVisibility="Auto"
                   Text="— Session not started. Click Connect. —&#10;"/>

        </StackPanel>
      </TabItem>

      <TabItem Header="  Support Chat  " FontSize="13" Foreground="White">
        <DockPanel Margin="16" Background="#12121F">

          <Grid DockPanel.Dock="Bottom"
                ColumnDefinitions="*,Auto"
                Margin="0,8,0,0" Height="40">
            <TextBox x:Name="txtChatMessage"
                     Grid.Column="0"
                     PlaceholderText="Type a message..."
                     Margin="0,0,8,0"
                     FontSize="13"
                     Background="#1E1E35"
                     Foreground="White"
                     CaretBrush="White"
                     KeyDown="TxtChat_KeyDown"/>
            <Button x:Name="btnSendChat"
                    Grid.Column="1"
                    Content="Send"
                    Width="96"
                    Background="#185FA5"
                    Foreground="White"
                    Click="BtnSendChat_Click"/>
          </Grid>

          <TextBox x:Name="rtbChatLog"
                   IsReadOnly="True"
                   AcceptsReturn="True"
                   FontSize="12"
                   Background="#0A0A15"
                   Foreground="#E0E0E0"
                   TextWrapping="Wrap"
                   ScrollViewer.VerticalScrollBarVisibility="Auto"
                   Text="— Connect to start chatting. —&#10;"/>

        </DockPanel>
      </TabItem>

      <TabItem Header="  Live Rates  " FontSize="13" Foreground="White">
        <StackPanel Margin="16" Spacing="14" Background="#12121F">

          <Grid ColumnDefinitions="*,Auto" Height="36">
            <TextBlock x:Name="lblLastUpdated"
                       Grid.Column="0"
                       Text="Last updated: —"
                       Foreground="#888888"
                       FontSize="12"
                       VerticalAlignment="Center"/>
            <Button x:Name="btnRefresh"
                    Grid.Column="1"
                    Content="Refresh Rates"
                    Width="130"
                    Background="#185FA5"
                    Foreground="White"
                    Click="BtnRefresh_Click"/>
          </Grid>

          <Grid ColumnDefinitions="*,*"
                RowDefinitions="Auto,Auto"
                ColumnSpacing="12"
                RowSpacing="12">

            <Border Grid.Row="0" Grid.Column="0"
                    Background="#0D2137"
                    BorderBrush="#185FA5"
                    BorderThickness="1"
                    CornerRadius="8">
              <StackPanel Margin="14,12">
                <TextBlock Text="USD / EGP"
                           FontSize="11" Foreground="#5B9BD5"/>
                <TextBlock x:Name="lblUSD"
                           Text="—"
                           FontSize="28"
                           FontWeight="Bold"
                           Foreground="#60B8FF"/>
              </StackPanel>
            </Border>

            <Border Grid.Row="0" Grid.Column="1"
                    Background="#0D2110"
                    BorderBrush="#2E7D32"
                    BorderThickness="1"
                    CornerRadius="8">
              <StackPanel Margin="14,12">
                <TextBlock Text="EUR / EGP"
                           FontSize="11" Foreground="#4CAF50"/>
                <TextBlock x:Name="lblEUR"
                           Text="—"
                           FontSize="28"
                           FontWeight="Bold"
                           Foreground="#00E676"/>
              </StackPanel>
            </Border>

            <Border Grid.Row="1" Grid.Column="0"
                    Background="#210D0D"
                    BorderBrush="#C62828"
                    BorderThickness="1"
                    CornerRadius="8">
              <StackPanel Margin="14,12">
                <TextBlock Text="GBP / EGP"
                           FontSize="11" Foreground="#EF5350"/>
                <TextBlock x:Name="lblGBP"
                           Text="—"
                           FontSize="28"
                           FontWeight="Bold"
                           Foreground="#FF5252"/>
              </StackPanel>
            </Border>

            <Border Grid.Row="1" Grid.Column="1"
                    Background="#211A0D"
                    BorderBrush="#F9A825"
                    BorderThickness="1"
                    CornerRadius="8">
              <StackPanel Margin="14,12">
                <TextBlock Text="SAR / EGP"
                           FontSize="11" Foreground="#FFB300"/>
                <TextBlock x:Name="lblSAR"
                           Text="—"
                           FontSize="28"
                           FontWeight="Bold"
                           Foreground="#FFD740"/>
              </StackPanel>
            </Border>

          </Grid>
        </StackPanel>
      </TabItem>

    </TabControl>
  </DockPanel>
</Window>